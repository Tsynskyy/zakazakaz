{
  "name": "zakazakaz",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "generate": "openapi-typescript openapi/spec.yaml -o src/generated/api.ts",
    "build": "npm run generate && tsc",
    "start": "node dist/index.js",
    "dev": "npm run generate && tsx src/index.ts"
  },
  "dependencies": {
    "express": "^4.21.2",
    "express-openapi-validator": "^5.6.2",
    "pg": "^8.19.0",
    "jsonwebtoken": "^9.0.3",
    "bcrypt": "^6.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.16.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/bcrypt": "^6.0.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3",
    "tsx": "^4.21.0"
  }
}
